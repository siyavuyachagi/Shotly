{
    "compilerOptions": {
        "types": ["node"],
      "module": "commonjs",
      "target": "ES2020",
      "outDir": "dist",
      "rootDir": "src",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "sourceMap": true,
      "resolveJsonModule": true
    },
    "include": ["src", "_webview"],
    "exclude": ["node_modules", ".vscode-test"]
  }